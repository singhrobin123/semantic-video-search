# =============================================================================
# Semantic Video Search Engine — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- LLM Providers -----------------------------------------------------------
# At least one provider is required. OpenAI is the default.
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Enable Anthropic as an alternative/fallback provider
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# --- LLM Configuration -------------------------------------------------------
LLM_PROVIDER=openai                    # openai | anthropic
LLM_MODEL=gpt-4o-mini                  # gpt-4o-mini | gpt-4o | claude-sonnet-4-20250514
LLM_TEMPERATURE=0.1                    # Low temperature for factual retrieval
EMBEDDING_MODEL=text-embedding-3-small # OpenAI embedding model

# --- Database (PostgreSQL + pgvector) ----------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vectordb
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Vector Search Tuning ----------------------------------------------------
VECTOR_SEARCH_TOP_K=20                 # Initial KNN candidate count
VECTOR_SEARCH_RERANK_TOP_K=5           # Post-rerank result count
HNSW_M=16                              # HNSW index connectivity
HNSW_EF_CONSTRUCTION=64                # HNSW build-time quality

# --- Application --------------------------------------------------------------
APP_ENV=development                    # development | staging | production
APP_LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
APP_CORS_ORIGINS=["http://localhost:8501","http://localhost:3000"]
